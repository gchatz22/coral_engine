# Example environment for the Coral dev loop.
#
# Copy to `.env` (gitignored) and adjust as needed. These values target
# the recommended dev shape: backing services in Docker (per
# `docker-compose.yml`), worker running natively on the host via
# `cargo run -p coral_worker --bin worker`. From the host, the
# containers are reached via the published ports on `localhost`.
#
# If you instead run the worker inside the compose network (e.g.
# `docker compose --profile container-worker up worker`), substitute
# `localhost` with the service name (`postgres`, `temporal`) — the
# compose file already wires that variant via the service's `environment:`
# block, so you don't need to edit anything here.

# Structural DB (stage 1 lands the schema; for now the DB exists, empty).
DATABASE_URL=postgres://coral:coral@localhost:5432/coral_structural

# Temporal frontend gRPC endpoint. Needs the `http://` scheme — the worker
# parses it as a URL. This matches the worker's default when unset.
TEMPORAL_ADDRESS=http://localhost:7233
TEMPORAL_NAMESPACE=default

# Canonical task queue the worker daemon listens on and operator CLIs
# dispatch to. Defaults to `coral-agents` (the value exported as
# `coral_temporal::worker::DEFAULT_TASK_QUEUE`) — leave commented unless
# you need to shard a personal queue for isolation or fleet-shard across
# multiple worker pools. The worker binary reads this env var; thin-
# client CLIs will too as they land (JAR2-76).
# TEMPORAL_TASK_QUEUE=coral-agents

# Per-agent FS root. In the native dev loop, this is wherever you want
# the worker to write its on-disk state — usually the host bind-mount
# directory so the container path and the host path agree.
AGENT_FS_ROOT=./agent-fs

# Log level. `info` is the default; bump to `debug` or `trace` for
# diagnosis. Honors the standard `tracing-subscriber` env-filter syntax.
RUST_LOG=info
