{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT a.id, a.graph_id, a.name,\n                   a.created_at as \"created_at!: chrono::DateTime<chrono::Utc>\"\n            FROM agents a\n            JOIN edges e ON e.child_agent_id = a.id\n            WHERE e.parent_agent_id = $1\n            ORDER BY a.created_at ASC\n            ",
